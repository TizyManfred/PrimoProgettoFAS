{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 📊 Aviation Data Analysis: Insights & Trends\n",
        "\n",
        "Questo notebook analizza il dataset pulito degli incidenti aerei per estrarre tendenze storiche, correlazioni tra fattori tecnici e gravità, e distribuzioni geografiche globali.\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "import sys\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import plotly.express as px\n",
        "import plotly.graph_objects as go\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "import plotly.io as pio\n",
        "pio.renderers.default = \"notebook_connected\""
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Caricamento e Preparazione\n",
        "Carichiamo il dataset e assicuriamoci che le coordinate siano numeriche per la mappatura."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(\"__file__\")))\n",
        "CLEAN_CSV = os.path.join(BASE_DIR, \"data\", \"cleaned\", \"aviation_clean.csv\")\n",
        "\n",
        "df = pd.read_csv(CLEAN_CSV, low_memory=False)\n",
        "\n",
        "# Conversione coordinate per mappatura\n",
        "df[\"latitude\"] = pd.to_numeric(df[\"latitude\"], errors=\"coerce\")\n",
        "df[\"longitude\"] = pd.to_numeric(df[\"longitude\"], errors=\"coerce\")\n",
        "\n",
        "print(f\"Dataset pronto: {len(df)} record.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Cluster Geografico (Mappa Globale)\n",
        "Visualizziamo la densità degli incidenti mondo attraverso le coordinate GPS."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "df_map = df.dropna(subset=[\"latitude\", \"longitude\"]).sample(min(5000, len(df)))\n",
        "fig = px.scatter_geo(df_map, lat=\"latitude\", lon=\"longitude\", \n",
        "                     color=\"severity_class\",\n",
        "                     hover_name=\"make\",\n",
        "                     title=\"Distribuzione Globale degli Incidenti (Campione 5000 eventi)\",\n",
        "                     template=\"plotly_dark\")\n",
        "fig.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Matrice di Correlazione\n",
        "Esiste una relazione tra il numero di motori, l'anno dell'evento e il numero di feriti?"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "corr_cols = [\"number_of_engines\", \"year\", \"total_fatal_injuries\", \"total_serious_injuries\", \"total_injuries\"]\n",
        "plt.figure(figsize=(10, 8))\n",
        "sns.heatmap(df[corr_cols].corr(), annot=True, cmap=\"coolwarm\", fmt=\".2f\")\n",
        "plt.title(\"Matrice di Correlazione Fattori Tecnici\")\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Analisi Fatality Rate per Decennio\n",
        "Calcoliamo la percentuale di incidenti con vittime fatali divise per decennio."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "df[\"decade\"] = (df[\"year\"] // 10) * 10\n",
        "fatality_rate = df.groupby(\"decade\").apply(\n",
        "    lambda x: (x[\"severity_class\"] == \"Fatal\").sum() / len(x) * 100\n",
        ").reset_index(name=\"fatality_pct\")\n",
        "\n",
        "fig = px.bar(fatality_rate, x=\"decade\", y=\"fatality_pct\", \n",
        "             title=\"Tasso di Letalità per Decennio (%)\",\n",
        "             labels={\"decade\": \"Decennio\", \"fatality_pct\": \"Percentuale Fatali\"}, \n",
        "             color=\"fatality_pct\", color_continuous_scale=\"Viridis\")\n",
        "fig.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5. Salvataggio Aggregazioni\n",
        "Eseguiamo le aggregazioni classiche per la dashboard."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "AGG_DIR = os.path.join(BASE_DIR, \"data\", \"aggregated\")\n",
        "os.makedirs(AGG_DIR, exist_ok=True)\n",
        "\n",
        "df.groupby(\"year\").size().to_csv(os.path.join(AGG_DIR, \"accidents_per_year.csv\"))\n",
        "df.groupby(\"broad_phase_of_flight\").size().to_csv(os.path.join(AGG_DIR, \"by_flight_phase.csv\"))\n",
        "print(\"Aggregazioni salvate.\")"
      ]
    }
  ],\n",
